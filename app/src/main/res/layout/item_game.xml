<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/gameCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <!-- COVER -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/gameCover"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:contentDescription="@string/featured_game"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent" />

        <!-- CHIP TAG -->
        <com.google.android.material.chip.Chip
            android:id="@+id/gameTag"
            style="@style/Widget.MaterialComponents.Chip.Action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"
            android:text="New"
            android:textSize="10sp"
            android:visibility="gone"
            app:chipBackgroundColor="@color/accent"
            app:chipCornerRadius="12dp"
            app:chipMinHeight="20dp"
            app:layout_constraintStart_toStartOf="@id/gameCover"
            app:layout_constraintTop_toTopOf="@id/gameCover" />

        <!-- FAVORITE -->
        <ImageButton
            android:id="@+id/btnFavorite"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_wishlist"
            android:src="@android:drawable/btn_star_big_off"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/gameCover"
            app:layout_constraintEnd_toEndOf="@id/gameCover"
            app:tint="@color/warning" />

        <!-- TITLE -->
        <TextView
            android:id="@+id/gameTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceSubtitle2"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/gameCover"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Cyber Adventure 2077" />

        <!-- GENRE/PLATFORM -->
        <TextView
            android:id="@+id/gameGenre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceCaption"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/gameTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="RPG • Steam" />

        <!-- RATING -->
        <LinearLayout
            android:id="@+id/ratingContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/gameGenre"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:contentDescription="@string/game_rating"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="@color/warning" />

            <TextView
                android:id="@+id/gameRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="4.5"
                android:textAppearance="?attr/textAppearanceCaption"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- PRICE + BUTTON -->
        <LinearLayout
            android:id="@+id/bottomContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/ratingContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/gamePrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="?attr/textAppearanceSubtitle2"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:textSize="14sp"
                tools:text="1999 ₽" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddToCart"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:visibility="gone"
                app:icon="@android:drawable/ic_menu_add"
                app:iconSize="16dp"
                app:cornerRadius="16dp"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>